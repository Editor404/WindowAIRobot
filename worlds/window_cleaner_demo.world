<?xml version="1.0"?>
<sdf version="1.6">
  <world name="window_cleaner_demo">
    <physics name="default_physics" type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_update_rate>1000</real_time_update_rate>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <scene>
      <ambient>0.35 0.35 0.35 1</ambient>
      <background>0.78 0.86 0.95 1</background>
      <shadows>true</shadows>
    </scene>

    <include>
      <uri>model://sun</uri>
    </include>


    <plugin name="gazebo_ros_state" filename="libgazebo_ros_state.so">
      <ros>
        <namespace>/gazebo</namespace>
      </ros>
      <update_rate>30.0</update_rate>
    </plugin>

    <!-- Horizontal floor for ordinary traction tests before wall adhesion tests. -->
    <model name="traction_test_floor">
      <static>true</static>
      <pose>0.35 0 0 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>3.0 2.0 0.04</size>
            </box>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>1.1</mu>
                <mu2>1.1</mu2>
              </ode>
            </friction>
          </surface>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>3.0 2.0 0.04</size>
            </box>
          </geometry>
          <material>
            <ambient>0.55 0.55 0.55 1</ambient>
            <diffuse>0.62 0.62 0.62 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Vertical window: glass lower-left corner is world (0, 0, 0); glass spans Y=0..0.8 m and Z=0..1.6 m. The frame border thickness is 5 cm and protrudes 20 cm toward +X. -->
    <model name="window_wall">
      <static>true</static>
      <pose>0 0.4 0.8 0 0 0</pose>
      <link name="link">
        <collision name="glass_collision">
          <geometry>
            <box>
              <size>0.02 0.8 1.6</size>
            </box>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>0.9</mu>
                <mu2>0.9</mu2>
              </ode>
            </friction>
          </surface>
        </collision>
        <visual name="glass">
          <geometry>
            <box>
              <size>0.02 0.8 1.6</size>
            </box>
          </geometry>
          <material>
            <ambient>0.62 0.86 1.0 0.55</ambient>
            <diffuse>0.62 0.86 1.0 0.55</diffuse>
            <specular>0.7 0.9 1.0 1</specular>
          </material>
        </visual>

        <collision name="frame_top_collision">
          <pose>0.10 0 0.825 0 0 0</pose>
          <geometry>
            <box>
              <size>0.20 0.90 0.05</size>
            </box>
          </geometry>
        </collision>
        <visual name="frame_top">
          <pose>0.10 0 0.825 0 0 0</pose>
          <geometry>
            <box>
              <size>0.20 0.90 0.05</size>
            </box>
          </geometry>
          <material>
            <ambient>0.08 0.08 0.08 1</ambient>
            <diffuse>0.08 0.08 0.08 1</diffuse>
          </material>
        </visual>

        <collision name="frame_bottom_collision">
          <pose>0.10 0 -0.825 0 0 0</pose>
          <geometry>
            <box>
              <size>0.20 0.90 0.05</size>
            </box>
          </geometry>
        </collision>
        <visual name="frame_bottom">
          <pose>0.10 0 -0.825 0 0 0</pose>
          <geometry>
            <box>
              <size>0.20 0.90 0.05</size>
            </box>
          </geometry>
          <material>
            <ambient>0.08 0.08 0.08 1</ambient>
            <diffuse>0.08 0.08 0.08 1</diffuse>
          </material>
        </visual>

        <collision name="frame_left_collision">
          <pose>0.10 -0.425 0 0 0 0</pose>
          <geometry>
            <box>
              <size>0.20 0.05 1.70</size>
            </box>
          </geometry>
        </collision>
        <visual name="frame_left">
          <pose>0.10 -0.425 0 0 0 0</pose>
          <geometry>
            <box>
              <size>0.20 0.05 1.70</size>
            </box>
          </geometry>
          <material>
            <ambient>0.08 0.08 0.08 1</ambient>
            <diffuse>0.08 0.08 0.08 1</diffuse>
          </material>
        </visual>

        <collision name="frame_right_collision">
          <pose>0.10 0.425 0 0 0 0</pose>
          <geometry>
            <box>
              <size>0.20 0.05 1.70</size>
            </box>
          </geometry>
        </collision>
        <visual name="frame_right">
          <pose>0.10 0.425 0 0 0 0</pose>
          <geometry>
            <box>
              <size>0.20 0.05 1.70</size>
            </box>
          </geometry>
          <material>
            <ambient>0.08 0.08 0.08 1</ambient>
            <diffuse>0.08 0.08 0.08 1</diffuse>
          </material>
        </visual>

        <!-- Random dirt dots are standalone models below so they can be deleted when cleaned. -->

      </link>
    </model>

